<%@ page contentType="text/html; charset=UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<c:choose><c:when test="${empty workOrder}"><div class="taFormShell taEmptyState"><p>조회된 작업지시 정보가 없습니다.</p><div class="taPageActions" style="justify-content:center; margin-top:16px;"><a class="taBtn taBtnOutline" href="${pageContext.request.contextPath}/workorder/list" style="text-decoration:none;">목록</a></div></div></c:when><c:otherwise><div class="taSectionStack"><form action="${pageContext.request.contextPath}/workorder/update" method="post"><input type="hidden" name="workOrderId" value="${workOrder.workOrderId}"><div class="taPageActions"><button type="submit" class="taBtn taBtnPrimary">수정</button><a class="taBtn taBtnOutline" href="${pageContext.request.contextPath}/workorder/list" style="text-decoration:none;">목록</a><a class="taBtn taBtnOutline" href="${pageContext.request.contextPath}/productionresult/list?workOrderId=${workOrder.workOrderId}" style="text-decoration:none;">생산실적</a></div><div class="taFormShell"><table class="taFormTable"><tr><th class="taFormLabel">작업지시번호</th><td class="taFormValue"><span class="taReadonlyText">${workOrder.workOrderId}</span></td></tr><tr><th class="taFormLabel">작업지시코드</th><td class="taFormValue"><span class="taReadonlyText">${workOrder.workOrderDisplayCode}</span></td></tr><tr><th class="taFormLabel">품목명</th><td class="taFormValue"><span class="taReadonlyText">${workOrder.itemName}</span></td></tr><tr><th class="taFormLabel">작업자</th><td class="taFormValue"><span class="taReadonlyText">${workOrder.empName}</span></td></tr><tr><th class="taFormLabel">지시일</th><td class="taFormValue"><input class="taFormInput" type="date" name="workDate" value="${workOrder.workDate}"></td></tr><tr><th class="taFormLabel">지시수량</th><td class="taFormValue"><input class="taFormInput" type="number" step="0.001" name="workQty" value="${workOrder.workQty}"></td></tr><tr><th class="taFormLabel">비고</th><td class="taFormValue"><textarea class="taFormTextarea" name="remark">${workOrder.remark}</textarea></td></tr></table></div></form>
<div><div class="taSectionTitle">BOM</div><div class="taTableShell"><div class="taTableScroll"><table class="taMesTable"><thead><tr><th class="taTableHeadCell taColFit">BOM ID</th><th class="taTableHeadCell taColFit">자재코드</th><th class="taTableHeadCell taColGrow">자재명</th><th class="taTableHeadCell taColFit">단위</th><th class="taTableHeadCell taColFit taLastCol">소요량</th></tr></thead><tbody><c:choose><c:when test="${not empty bomList}"><c:forEach var="bom" items="${bomList}"><tr class="taTableBodyRow"><td class="taTableBodyCell taColFit">${bom.bomId}</td><td class="taTableBodyCell taColFit">${bom.childItemCode}</td><td class="taTableBodyCell taColGrow">${bom.childItemName}</td><td class="taTableBodyCell taColFit">${bom.unit}</td><td class="taTableBodyCell taColFit taLastCol">${bom.requiredQty}</td></tr></c:forEach></c:when><c:otherwise><tr class="taTableBodyRow"><td class="taTableBodyCell taLastCol" colspan="5" style="text-align:center;">등록된 BOM 정보가 없습니다.</td></tr></c:otherwise></c:choose></tbody></table></div></div></div>
<div><div class="taSectionTitle">라우팅</div><c:choose><c:when test="${not empty routingList}"><div class="taRoutingFlow"><c:forEach var="routing" items="${routingList}" varStatus="st"><div class="taRoutingStep"><div class="taRoutingOrder">STEP ${routing.processSeq}</div><div class="taRoutingName">${routing.processName}</div><div class="taRoutingSub">공정코드: ${routing.processCode}<br>설비: ${routing.equipmentName}</div></div><c:if test="${not st.last}"><div class="taRoutingArrow">→</div></c:if></c:forEach></div></c:when><c:otherwise><div class="taFormShell taEmptyState">등록된 라우팅 정보가 없습니다.</div></c:otherwise></c:choose></div></div></c:otherwise></c:choose>
