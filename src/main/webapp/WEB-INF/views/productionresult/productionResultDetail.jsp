<%@ page contentType="text/html; charset=UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<c:choose><c:when test="${empty productionResult}"><div class="taFormShell taEmptyState"><p>조회된 생산실적 정보가 없습니다.</p><div class="taPageActions" style="justify-content:center; margin-top:16px;"><a class="taBtn taBtnOutline" href="${pageContext.request.contextPath}/workorder/list" style="text-decoration:none;">작업지시 목록</a></div></div></c:when><c:otherwise><form action="${pageContext.request.contextPath}/productionresult/update" method="post"><input type="hidden" name="resultId" value="${productionResult.resultId}"><div class="taPageActions"><button type="submit" class="taBtn taBtnPrimary">수정</button><a class="taBtn taBtnOutline" href="${pageContext.request.contextPath}/productionresult/list?workOrderId=${productionResult.workOrderId}" style="text-decoration:none;">목록</a></div><div class="taFormShell"><table class="taFormTable"><tr><th class="taFormLabel">실적번호</th><td class="taFormValue"><span class="taReadonlyText">${productionResult.resultId}</span></td></tr><tr><th class="taFormLabel">작업지시번호</th><td class="taFormValue"><span class="taReadonlyText">${productionResult.workOrderId}</span></td></tr><tr><th class="taFormLabel">품목명</th><td class="taFormValue"><span class="taReadonlyText">${productionResult.itemName}</span></td></tr><tr><th class="taFormLabel">작업자</th><td class="taFormValue"><span class="taReadonlyText">${productionResult.empName}</span></td></tr><tr><th class="taFormLabel">실적일</th><td class="taFormValue"><input class="taFormInput" type="date" name="resultDate" value="${productionResult.resultDate}"></td></tr><tr><th class="taFormLabel">LOT NO</th><td class="taFormValue"><input class="taFormInput" type="text" name="lotNo" value="${productionResult.lotNo}"></td></tr><tr><th class="taFormLabel">생산수량</th><td class="taFormValue"><input class="taFormInput" type="number" step="0.001" name="producedQty" value="${productionResult.producedQty}"></td></tr><tr><th class="taFormLabel">손실수량</th><td class="taFormValue"><input class="taFormInput" type="number" step="0.001" name="lossQty" value="${productionResult.lossQty}"></td></tr><tr><th class="taFormLabel">상태</th><td class="taFormValue"><input class="taFormInput" type="text" name="status" value="${productionResult.status}"></td></tr><tr><th class="taFormLabel">비고</th><td class="taFormValue"><textarea class="taFormTextarea" name="remark">${productionResult.remark}</textarea></td></tr></table></div></form></c:otherwise></c:choose>
